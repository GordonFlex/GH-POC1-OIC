<adapter-config xsdTargetNamespace="http://xmlns.oracle.com/cloud/adapter/appevent/SMS_EVENT_TEST1_REQUEST/types" name="SMS_EVENT_TEST1_REQUESTPortType" adapter="appevent" wsdlLocation="SMS_EVENT_TEST1_REQUEST.wsdl" xmlns="http://platform.integration.oracle/blocks/adapter/fw/metadata">
